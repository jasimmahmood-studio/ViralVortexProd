# ============================================================
#  ViralVortex — Environment Variables
#  Copy this file to .env and fill in your API keys
#  Then run: source .env  OR  use python-dotenv
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────

# Claude AI (for script generation)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# YouTube Data API v3 (for trending + upload)
# Get from: https://console.cloud.google.com/
# Enable: YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── OPTIONAL (but recommended) ──────────────────────────────

# ElevenLabs (high-quality voiceover)
# Get from: https://elevenlabs.io/
# Free tier: 10,000 chars/month
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Pexels (free stock footage)
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key_here

# OpenAI DALL-E 3 (AI thumbnail backgrounds)
# Get from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_key_here

# ── NOTIFICATIONS (optional) ────────────────────────────────

# Slack webhook for daily reports
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Gmail for email reports (use App Password, not real password)
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
REPORT_EMAIL=your.email@gmail.com

# ── UPLOAD SETTINGS ─────────────────────────────────────────

# Video privacy: public | unlisted | private
YOUTUBE_PRIVACY=public

# Upload time (24h format, server local time)
UPLOAD_TIME=07:30
